# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# uv / venv
.venv/
# (uv.lock IS committed — Diannot is an app, so we pin for reproducibility.)

# Diannot output (rendered HTML/PDF/PNG)
output/

# Credentials / local config
.env
*.local.toml

# Full-text search index
.diannot_index.db
*.diannot_index.db

# NiceGUI / Diannot Studio server storage
.nicegui/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Scratch
_pdfpeek/

# Release-only secret: the bundled Gemini key + default-engine config (never committed)
src/diannot/studio/_embedded.py
# Offline release-signing PRIVATE keys (Ed25519) — NEVER commit. Generated by scripts/gen_release_key.py.
# Broad patterns so a rotated key under ANY name can't slip into a `git add -A`.
diannot_release_private_key.b64
*release_private_key*.b64
*private_key*.b64
*signing*key*.b64
*.key
# Built installer output (the signed manifest.json + manifest.sig are written here too)
dist/installer/

# Personal source notes (large binaries kept out of history; store under a notebook later)
/*.pdf

# Local import artifacts created when testing the studio against the sample notebook
examples/sample_notebook/_imports/
