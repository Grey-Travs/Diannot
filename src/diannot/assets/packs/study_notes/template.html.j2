{#- study_notes pack: two-column, light/playful "aesthetic study-notes" layout. -#}
{% macro render_list(items, ordered) %}
<{{ 'ol' if ordered else 'ul' }} class="list">
{% for it in items %}
  <li>{{ it.text | inline_md }}{% if it.children %}{{ render_list(it.children, ordered) }}{% endif %}</li>
{% endfor %}
</{{ 'ol' if ordered else 'ul' }}>
{% endmacro %}
{% macro render_block(b, note=none) %}
{% set _lay = {'col1': 'lay-col1', 'col2': 'lay-col2', 'full': 'lay-full'}.get(b.layout, '') %}
{% set cls = (_lay ~ ' ' ~ ('flag-' ~ b.confidence if b.confidence in ['low', 'medium'] else '')) | trim %}
{% if b.type == 'banner' %}
  <header class="banner {{ cls }}">
    {% if b.images %}<div class="banner-imgs">{% for im in b.images %}<img src="{{ im }}" alt="">{% endfor %}</div>{% endif %}
    {% if note and note.subject %}<div class="banner-eyebrow">{{ note.subject }}{% if note.chapter %} &middot; Chapter {{ note.chapter }}{% endif %}</div>{% endif %}
    <h1>{{ b.text }}</h1>
    {% if b.subtitle %}<p class="banner-sub">{{ b.subtitle }}</p>{% endif %}
  </header>
{% elif b.type == 'script_heading' %}
  <h2 class="script-h {{ cls }}">{{ b.text }}</h2>
{% elif b.type == 'subheading' %}
  <h3 class="subhead {{ 'caps' if b.caps else '' }} {{ cls }}">{{ b.text }}</h3>
{% elif b.type == 'body' %}
  <p class="body {{ cls }}">{{ b.text | inline_md }}</p>
{% elif b.type == 'term_definition' %}
  <p class="termdef {{ cls }}"><span class="term">{{ b.term }}</span> <span class="dash">&mdash;</span> {{ b.definition | inline_md }}</p>
{% elif b.type == 'list' %}
  <div class="list-wrap {{ cls }}">{{ render_list(b.items, b.ordered) }}</div>
{% elif b.type == 'table' %}
  <figure class="table-wrap {{ cls }}">
    <div class="tbl-box">
    <table class="tbl">
      <thead><tr>{% for h in b.headers %}<th>{{ h | inline_md }}</th>{% endfor %}</tr></thead>
      <tbody>
      {% for row in b.rows %}<tr>{% for cell in row %}<td>{{ cell | inline_md }}</td>{% endfor %}</tr>{% endfor %}
      </tbody>
    </table>
    </div>
    {% if b.caption %}<figcaption>{{ b.caption }}</figcaption>{% endif %}
  </figure>
{% elif b.type == 'image' %}
  <figure class="img {{ cls }}">
    <img src="{{ b.src }}" alt="{{ b.alt or b.caption or '' }}"{% if b.width %} style="width: {{ b.width }}%"{% endif %}>
    {% if b.caption or b.source_credit %}<figcaption>{{ b.caption or '' }}{% if b.source_credit %} <span class="credit">{{ b.source_credit }}</span>{% endif %}</figcaption>{% endif %}
  </figure>
{% elif b.type == 'diagram' %}
  <figure class="diagram {{ cls }}"><pre class="mermaid">{{ b.mermaid }}</pre>{% if b.caption %}<figcaption>{{ b.caption }}</figcaption>{% endif %}</figure>
{% elif b.type == 'callout' %}
  <aside class="callout {{ b.variant }} {{ cls }}">
    <span class="callout-ico">
      {%- if b.variant == 'tutor_tip' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 21h4"/><path d="M12 3a6 6 0 0 0-4 10.4c.6.5 1 1.3 1 2.1V16h6v-.5c0-.8.4-1.6 1-2.1A6 6 0 0 0 12 3Z"/></svg>
      {%- elif b.variant == 'warning' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5 21 19.5H3z"/><line x1="12" y1="10" x2="12" y2="14"/><circle cx="12" cy="17" r=".6" fill="currentColor" stroke="none"/></svg>
      {%- else -%}<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.2l2.7 5.86 6.4.55-4.85 4.2 1.46 6.27L12 15.9l-5.71 3.38 1.46-6.27L2.9 8.61l6.4-.55L12 2.2Z"/></svg>
      {%- endif -%}
    </span>
    <div class="callout-body">
      {% if b.title %}<div class="callout-title">{{ b.title }}</div>{% endif %}
      {% if b.body %}<p>{{ b.body | inline_md }}</p>{% endif %}
      {% if b.items %}<ul>{% for it in b.items %}<li>{{ it | inline_md }}</li>{% endfor %}</ul>{% endif %}
    </div>
  </aside>
{% elif b.type == 'quote' %}
  <blockquote class="quote {{ cls }}">{{ b.text | inline_md }}{% if b.attribution %}<cite>&mdash; {{ b.attribution }}</cite>{% endif %}</blockquote>
{% endif %}
{% endmacro %}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ note.title }}</title>
<style>
{{ font_css | safe }}
:root{
  --c-primary: {{ theme.colors.primary }};
  --c-primary-dark: {{ theme.colors.primary_dark }};
  --c-accent: {{ theme.colors.accent }};
  --c-accent-soft: {{ theme.colors.accent_soft }};
  --c-ink: {{ theme.colors.ink }};
  --c-page: {{ theme.colors.page }};
  --c-banner-fill: {{ theme.colors.banner_fill }};
  --c-banner-stroke: {{ theme.colors.banner_stroke }};
  --c-banner-shadow: {{ theme.colors.banner_shadow }};
  --c-thead-bg: {{ theme.colors.table_head_bg }};
  --c-thead-ink: {{ theme.colors.table_head_ink }};
  --c-zebra: {{ theme.colors.table_zebra }};
  --c-tip-bg: {{ theme.colors.callout_tip_bg }};
  --c-tip-border: {{ theme.colors.callout_tip_border }};
  --c-key-bg: {{ theme.colors.callout_key_bg }};
  --c-key-border: {{ theme.colors.callout_key_border }};
  --c-warn-bg: {{ theme.colors.callout_warn_bg }};
  --c-warn-border: {{ theme.colors.callout_warn_border }};
}
{{ pack_css | safe }}
</style>
</head>
<body>
{% if note.layout_mode == 'canvas' %}
<main class="canvas-page">
{% for b in note.blocks %}
  <div class="canvas-item"{% if b.box %} style="left:{{ b.box.x }}%;top:{{ b.box.y }}%;width:{{ b.box.w }}%;min-height:{{ b.box.h }}%;z-index:{{ b.box.z }}"{% endif %}>{{ render_block(b, note) }}</div>
{% endfor %}
</main>
{% else %}
<main class="page">
{% for g in groups %}{% if g[0] == 'full' %}{{ render_block(g[1], note) }}{% else %}<div class="cols"><div class="col">{% for b in g[1] %}{{ render_block(b, note) }}{% endfor %}</div><div class="col">{% for b in g[2] %}{{ render_block(b, note) }}{% endfor %}</div></div>{% endif %}{% endfor %}
{% if note.subject %}<footer class="note-foot"><span class="note-foot-l"><span class="note-foot-dot"></span>Diannot &middot; {{ note.subject }}</span></footer>{% endif %}
</main>
{% endif %}
{% if enable_mermaid %}{{ mermaid_html | safe }}{% endif %}
{% if enable_katex %}{{ katex_html | safe }}{% endif %}
</body>
</html>
